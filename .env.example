# Telegram (required)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Email / SMTP shared defaults (optional fallback)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Sender routing: Baeum (source contains baeum.ai.kr / baeum.io.kr / baeum.ai)
SMTP_FROM_BAEUM=no-reply@baeum.ai.kr
SMTP_FROM_NAME_BAEUM=배움 에이아이
SMTP_USER_BAEUM=
SMTP_PASSWORD_BAEUM=

# Sender routing: Ddok (source contains ddok.ai)
SMTP_FROM_DDOK=no-reply@ddok.ai
SMTP_FROM_NAME_DDOK=주식회사 똑똑한청년들
SMTP_USER_DDOK=
SMTP_PASSWORD_DDOK=

# Routing keywords (comma-separated, case-insensitive)
SMTP_URL_KEYWORDS_BAEUM=baeum.ai.kr,baeum.io.kr,baeum.ai
SMTP_URL_KEYWORDS_DDOK=ddok.ai

# Gmail API (optional, alternative to SMTP)
GMAIL_CREDENTIALS_PATH=/app/credentials/credentials.json
